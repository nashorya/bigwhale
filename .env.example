# QQ Bot 配置
ONEBOT_ACCESS_TOKEN=your_access_token_here

# 安全配置
SHORE_USER_SALT=your_random_32_char_salt_here

# 数据库路径
DB_PATH=data/kaoyan.db

# 积分配置
REGISTER_BONUS=200
INVITE_REWARD_INVITER=100
INVITE_REWARD_INVITEE=50
DAILY_SUBSCRIPTION_COST=20
PERSONA_UNLOCK_COST=80

# AI 配置（OpenAI 兼容协议）
API_KEY=your_api_key_here
BASE_URL=https://your-compatible-endpoint/v1
CHAT_MODEL=your_model_name_here

# Tavily Search API Key（用于搜索考研知识点，可选）
TAVILY_API_KEY=your_tavily_api_key_here

# 学信网账号（用于爬取研招网考试科目，可选）
# 注册地址：https://account.chsi.com.cn/
CHSI_USERNAME=your_chsi_username
CHSI_PASSWORD=your_chsi_password

# 智谱 AI 配置（Memory 系统 embedding）
# 获取地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here
