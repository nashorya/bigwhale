# 上岸 环境变量配置
# 复制此文件为 .env 并填写对应值
# 注意：.env 文件不得提交到 git

# ─────────────────────────────────────────────
# QQ Bot 配置
# ─────────────────────────────────────────────

# NapCat / Lagrange 的 access token（在协议端配置中设置）
ONEBOT_ACCESS_TOKEN=your_access_token_here

# NapCat WebSocket 地址（默认）
ONEBOT_WS_URL=ws://127.0.0.1:3001

# ─────────────────────────────────────────────
# 安全配置
# ─────────────────────────────────────────────

# 用户 ID 哈希盐值（32位随机字符串，部署后永不更换）
# 生成方式：python -c "import secrets; print(secrets.token_hex(16))"
SHORE_USER_SALT=your_random_32_char_salt_here

# ─────────────────────────────────────────────
# 数据库配置
# ─────────────────────────────────────────────

DB_PATH=data/kaoyan.db

# ─────────────────────────────────────────────
# AI 配置（OpenAI 兼容协议）
# ─────────────────────────────────────────────

# API Key / Base URL / 模型名均按你的中转站或服务商配置填写
API_KEY=your_api_key_here
BASE_URL=https://your-compatible-endpoint/v1

# 所有 AI 能力统一使用 CHAT_MODEL
CHAT_MODEL=

# Tavily Search API Key：用于搜索知识点（可选）
TAVILY_API_KEY=

# 智谱 AI Key：语义记忆 / embedding 功能（可选）
ZHIPU_API_KEY=

# ─────────────────────────────────────────────
# 积分配置
# ─────────────────────────────────────────────

# 注册赠送积分
REGISTER_BONUS=200

# 邀请奖励（邀请者）
INVITE_REWARD_INVITER=100

# 邀请奖励（被邀请者）
INVITE_REWARD_INVITEE=50

# 每日基础订阅费用
DAILY_SUBSCRIPTION_COST=20

# 推词加强档附加费用（每日）
WORD_TIER_ENHANCED_COST=5

# 推词冲刺档附加费用（每日）
WORD_TIER_SPRINT_COST=10

# 解锁人物卡费用
PERSONA_UNLOCK_COST=80

# 生成学习计划费用
PLAN_GENERATION_COST=50

# 情绪陪伴会话费用
EMOTION_SESSION_COST=5

# 学情报告费用
REPORT_GENERATION_COST=5

# ─────────────────────────────────────────────
# 调度配置
# ─────────────────────────────────────────────

# 早安推送时间（24小时制）
MORNING_PUSH_HOUR=7
MORNING_PUSH_MINUTE=30

# 晚间复盘时间
EVENING_PUSH_HOUR=22
EVENING_PUSH_MINUTE=30

# 每日计划重算时间
PLAN_CALC_HOUR=0
PLAN_CALC_MINUTE=5
